<?xml version="1.0" encoding="UTF-8"?>
<!-- Note: If file is named "ipconfig.xml" this data will be used as network configuration, otherwise server will configure it automatically! -->
<!-- Externalhost here (Internet IP) or Localhost IP for local test -->
<gameserver address="192.168.1.51" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../data/xsd/ipconfig.xsd">
	<!-- Localhost here -->
	<define subnet="127.0.0.0/8" address="127.0.0.1" />

	<!-- Internalhosts here (LANs IPs) -->
	<define subnet="192.168.1.0/24" address="192.168.1.0" />
	<define subnet="192.168.100.0/24" address="192.168.100.0" />

	<!-- CUALQUIER IP -->
	<define subnet="0.0.0.0/0" address="0.0.0.0" />

</gameserver>